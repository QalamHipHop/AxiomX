# --- General ---
NODE_ENV=development
PORT=3001

# --- Backend Security ---
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
ENCRYPTION_KEY=your_32_byte_base64_encryption_key_here
CORS_ORIGINS=http://localhost:3000,https://app.axiomx.io

# --- Databases ---
DATABASE_URL=postgresql://user:pass@localhost:5432/axiomx
TIMESCALEDB_URL=postgresql://user:pass@localhost:5432/axiomx_ts
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- CCXT Pro & Exchanges ---
CCXT_PRO_LICENSE=
BINANCE_API_KEY=
BINANCE_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=

# --- AI & External APIs ---
OPENAI_API_KEY=
SENTRY_DSN=
PROMETHEUS_PORT=9090

# --- Web3 ---
WALLETCONNECT_PROJECT_ID=
RPC_URL_ETHEREUM=
RPC_URL_POLYGON=

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100
