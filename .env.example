# Environment variables for AxiomX

# General
NODE_ENV=development
PORT=3000

# Backend
BACKEND_PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/axiomx_db"
REDIS_URL="redis://localhost:6379"

# CCXT Pro
CCXT_BINANCE_API_KEY=your_binance_api_key
CCXT_BINANCE_SECRET=your_binance_secret
# Add more exchange API keys as needed

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
